# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# IDE and agent ignore rules
.windsurf/
.kiro/
.vscode/
.cursor/
.antigravity/
.gemini/
.claude/
.codex/
.opencode/

# testing
/coverage

# next.js
/.next/
/out/

# swc
/.swc/

# production
/build

# misc
VERCEL_DEPLOYMENT_GUIDE.md
.DS_Store
*.pem
/docs

# Keep these for QuickJS setup
# /.github/
# /scripts/

# Python cache files (for API functions)
__pycache__/
*.pyc
*.pyo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.vercel
